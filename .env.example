# AgriDrop Environment Variables
# Copy this file to .env and fill in your API keys

# OpenWeather API Key
# Get it from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Maps API Key
# Get it from: https://cloud.google.com/maps-platform
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Database URL
# For SQLite (development): sqlite:///./agridrop.db
# For PostgreSQL: postgresql://user:password@localhost/agridrop
DATABASE_URL=sqlite:///./agridrop.db

# Application settings
DEBUG=False
PORT=8000
